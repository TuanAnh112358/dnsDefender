{
  "log_file": "data/query.log",
  "thresholds": {
    "query_count": 200,
    "time_window_minutes": 5,
    "nxdomain_ratio": 0.8,
    "amplification_threshold": 50
  },
  "whitelist_ips": ["127.0.0.1", "192.168.85.130"],
  "alert_email": "admin@example.com",
  "blocked_ip_log": "data/blocked_ips.txt",
  "alerts_log": "data/alerts_log.json",
  "use_dga_detection": true,
  "use_rpz_filtering": true,
  "rpz_file": "/etc/bind/db.rpz",
  "rate_limit": {
    "enabled": true,
    "rps": 5,
    "window": 5
  },
  "detection_rules": {
    "dns_flood": {
      "enabled": true,
      "threshold": 100,
      "window_minutes": 1
    },
    "nxdomain_flood": {
      "enabled": true,
      "threshold": 50,
      "ratio": 0.7
    },
    "amplification_detection": {
      "enabled": true,
      "suspicious_types": ["ANY", "TXT", "DNSKEY"],
      "threshold": 20
    }
  },
  "response_actions": {
    "block_ip": true,
    "add_to_rpz": true,
    "send_alert": true,
    "log_incident": true
  },
  "monitoring": {
    "check_interval_seconds": 30,
    "log_retention_days": 7,
    "stats_window_minutes": 15
  }
}